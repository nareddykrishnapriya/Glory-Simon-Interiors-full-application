{
  "name": "site-progress-reporting-system-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix frontend",
    "dev": "npm run dev --prefix frontend",
    "server": "python app.py",
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"bgBlue.bold,bgGreen.bold\" \"python app.py\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "build:deploy": "npm run build --prefix frontend && git add frontend/dist && git commit -m \"build: update frontend dist\" && git push"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
